{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "dev": "next dev --turbo",
    "dev:clean": "npm run clean && next dev --turbo",
    "dev:webpack": "next dev",
    "dev:lan": "next dev -H 0.0.0.0 --turbo",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.15",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
