{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start school app (build + run)",
      "type": "shell",
      "command": "npm run build && npm start",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": false
      }
    },
    {
      "label": "Safe start school app (reset :3000 + clean + build + run)",
      "type": "shell",
      "command": "sh -c \"PIDS=$(lsof -ti tcp:3000); if [ -n \\\"$PIDS\\\" ]; then kill $PIDS; fi; npm run clean && npm run build && npm start\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Rebuild school app (fix broken site)",
      "type": "shell",
      "command": "sh -c \"PIDS=$(lsof -ti tcp:3000 -ti tcp:3001); if [ -n \\\"$PIDS\\\" ]; then kill $PIDS; fi; npm run clean && npm run build\"",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": "build"
    },
    {
      "label": "Dev: live preview while editing",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": "none"
    },
    {
      "label": "Dev: clean cache then live preview",
      "type": "shell",
      "command": "npm run dev:clean",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "group": "none"
    },
    {
      "label": "Install packages (first time / after pull)",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      },
      "group": "none"
    }
  ]
}
